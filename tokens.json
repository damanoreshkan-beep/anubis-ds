{
    "$schema": "./schema.json",
    "$meta": {
        "name": "Anubis World Design System",
        "version": "1.0.0",
        "description": "Source of truth for design tokens. Tailwind preset, CSS variables, and theme classes in dist/ are generated from this file."
    },

    "color": {
        "primitive": {
            "brand": {
                "50":  "#f5f3ff",
                "100": "#ede9fe",
                "200": "#ddd6fe",
                "300": "#c4b5fd",
                "400": "#a78bfa",
                "500": "#8b5cf6",
                "600": "#7c3aed",
                "700": "#6d28d9",
                "800": "#5b21b6",
                "900": "#3b1574",
                "950": "#1e0a4a"
            },
            "violet": {
                "400": "#c084fc",
                "500": "#a855f7",
                "600": "#9333ea",
                "700": "#7e22ce",
                "900": "#3b0764",
                "950": "#1f0238"
            },
            "egypt": {
                "300": "#67e8f9",
                "400": "#22d3ee",
                "500": "#06b6d4",
                "600": "#0891b2",
                "700": "#0e7490",
                "900": "#164e63"
            },
            "amber": {
                "300": "#fcd34d",
                "400": "#fbbf24",
                "500": "#f59e0b",
                "600": "#d97706"
            },
            "surface": {
                "800": "#0c0a18",
                "900": "#070612",
                "950": "#040309"
            },
            "neutral": {
                "white":    "#ffffff",
                "black":    "#000000",
                "gray-300": "#d1d5db",
                "gray-400": "#9ca3af",
                "gray-500": "#6b7280",
                "gray-700": "#374151"
            }
        },

        "semantic": {
            "default": {
                "bg-page":         "{color.primitive.surface.950}",
                "bg-glass":        "{color.primitive.brand.500}",
                "bg-glass-hover":  "{color.primitive.brand.500}",
                "border-glass":    "{color.primitive.brand.500}",
                "border-glass-hover": "{color.primitive.violet.500}",
                "text-primary":    "{color.primitive.neutral.white}",
                "text-secondary":  "{color.primitive.neutral.gray-300}",
                "text-muted":      "{color.primitive.neutral.gray-500}",
                "text-accent":     "{color.primitive.brand.300}",
                "accent-primary":  "{color.primitive.brand.600}",
                "accent-hover":    "{color.primitive.brand.700}",
                "accent-cyan":     "{color.primitive.egypt.400}",
                "warning":         "{color.primitive.amber.400}"
            },
            "light": {
                "bg-page":         "{color.primitive.neutral.white}",
                "bg-glass":        "{color.primitive.brand.500}",
                "bg-glass-hover":  "{color.primitive.brand.500}",
                "border-glass":    "{color.primitive.brand.500}",
                "border-glass-hover": "{color.primitive.violet.500}",
                "text-primary":    "{color.primitive.surface.950}",
                "text-secondary":  "{color.primitive.neutral.gray-700}",
                "text-muted":      "{color.primitive.neutral.gray-500}",
                "text-accent":     "{color.primitive.brand.700}",
                "accent-primary":  "{color.primitive.brand.600}",
                "accent-hover":    "{color.primitive.brand.700}",
                "accent-cyan":     "{color.primitive.egypt.600}",
                "warning":         "{color.primitive.amber.500}"
            }
        },

        "shadcn": {
            "default": {
                "background":            "{color.primitive.surface.950}",
                "foreground":            "{color.primitive.neutral.white}",
                "card":                  "{color.primitive.surface.900}",
                "card-foreground":       "{color.primitive.neutral.white}",
                "popover":               "{color.primitive.surface.900}",
                "popover-foreground":    "{color.primitive.neutral.white}",
                "primary":               "{color.primitive.brand.600}",
                "primary-foreground":    "{color.primitive.neutral.white}",
                "secondary":             "{color.primitive.brand.950}",
                "secondary-foreground":  "{color.primitive.neutral.gray-300}",
                "muted":                 "{color.primitive.surface.800}",
                "muted-foreground":      "{color.primitive.neutral.gray-500}",
                "accent":                "{color.primitive.brand.800}",
                "accent-foreground":     "{color.primitive.neutral.white}",
                "destructive":           "#f43f5e",
                "destructive-foreground":"{color.primitive.neutral.white}",
                "border":                "{color.primitive.brand.950}",
                "input":                 "{color.primitive.surface.800}",
                "ring":                  "{color.primitive.brand.500}"
            },
            "light": {
                "background":            "{color.primitive.neutral.white}",
                "foreground":            "{color.primitive.surface.950}",
                "card":                  "{color.primitive.neutral.white}",
                "card-foreground":       "{color.primitive.surface.950}",
                "popover":               "{color.primitive.neutral.white}",
                "popover-foreground":    "{color.primitive.surface.950}",
                "primary":               "{color.primitive.brand.600}",
                "primary-foreground":    "{color.primitive.neutral.white}",
                "secondary":             "{color.primitive.brand.100}",
                "secondary-foreground":  "{color.primitive.brand.900}",
                "muted":                 "{color.primitive.brand.50}",
                "muted-foreground":      "{color.primitive.neutral.gray-500}",
                "accent":                "{color.primitive.brand.100}",
                "accent-foreground":     "{color.primitive.brand.700}",
                "destructive":           "#ef4444",
                "destructive-foreground":"{color.primitive.neutral.white}",
                "border":                "{color.primitive.brand.100}",
                "input":                 "{color.primitive.brand.100}",
                "ring":                  "{color.primitive.brand.500}"
            }
        },

        "alpha": {
            "glass-bg":            { "ref": "{color.primitive.brand.500}", "alpha": 0.06 },
            "glass-bg-hover":      { "ref": "{color.primitive.brand.500}", "alpha": 0.10 },
            "glass-border":        { "ref": "{color.primitive.brand.500}", "alpha": 0.18 },
            "glass-border-hover":  { "ref": "{color.primitive.violet.500}", "alpha": 0.40 },
            "glow-brand-soft":     { "ref": "{color.primitive.brand.600}", "alpha": 0.18 },
            "glow-egypt-soft":     { "ref": "{color.primitive.egypt.400}", "alpha": 0.20 }
        }
    },

    "spacing": {
        "xs":  4,
        "sm":  8,
        "md":  12,
        "lg":  16,
        "xl":  24,
        "2xl": 32,
        "3xl": 48
    },

    "radius": {
        "sm":   8,
        "md":   12,
        "lg":   16,
        "xl":   20,
        "2xl":  24,
        "full": 9999
    },

    "font": {
        "family": {
            "sans": ["Inter", "system-ui", "sans-serif"]
        },
        "size": {
            "xs":   12,
            "sm":   14,
            "base": 16,
            "lg":   18,
            "xl":   20,
            "2xl":  24,
            "3xl":  30,
            "5xl":  48
        },
        "lineHeight": {
            "tight":   1.2,
            "normal":  1.5,
            "relaxed": 1.75
        },
        "weight": {
            "normal":   400,
            "medium":   500,
            "semibold": 600,
            "bold":     700,
            "black":    900
        }
    },

    "shadow": {
        "glow-brand": "0 8px 32px {color.alpha.glow-brand-soft}",
        "glow-egypt": "0 8px 24px {color.alpha.glow-egypt-soft}"
    },

    "gradient": {
        "gold-text":      "linear-gradient(135deg, #c084fc 0%, #a855f7 50%, #22d3ee 100%)",
        "button-primary": "linear-gradient(135deg, #7c3aed 0%, #8b5cf6 100%)"
    },

    "animation": {
        "float": {
            "duration": "6s",
            "easing":   "ease-in-out",
            "iteration":"infinite",
            "keyframes": {
                "0%,100%": { "transform": "translateY(0)" },
                "50%":     { "transform": "translateY(-12px)" }
            }
        },
        "glow": {
            "duration": "2s",
            "easing":   "ease-in-out",
            "iteration":"infinite",
            "direction":"alternate",
            "keyframes": {
                "0%":   { "boxShadow": "0 0 20px rgba(139,92,246,.25)" },
                "100%": { "boxShadow": "0 0 50px rgba(139,92,246,.55)" }
            }
        },
        "twinkle": {
            "duration": "4s",
            "easing":   "ease-in-out",
            "iteration":"infinite",
            "keyframes": {
                "0%,100%": { "opacity": ".25", "transform": "scale(1)" },
                "50%":     { "opacity": ".85", "transform": "scale(1.4)" }
            }
        },
        "auraPulse": {
            "duration": "5s",
            "easing":   "ease-in-out",
            "iteration":"infinite",
            "keyframes": {
                "0%,100%": { "transform": "scale(1)",    "opacity": ".9" },
                "50%":     { "transform": "scale(1.08)", "opacity": "1"  }
            }
        },
        "borderPulse": {
            "duration": "3s",
            "easing":   "ease-in-out",
            "iteration":"infinite",
            "keyframes": {
                "0%,100%": { "borderColor": "rgba(139,92,246,.18)" },
                "50%":     { "borderColor": "rgba(168,85,247,.4)" }
            }
        },
        "particleFloat": {
            "duration": "var(--particle-duration, 12s)",
            "easing":   "linear",
            "iteration":"infinite",
            "keyframes": {
                "0%":   { "transform": "translateY(100vh) scale(0)", "opacity": "0" },
                "10%":  { "opacity": "1" },
                "90%":  { "opacity": "1" },
                "100%": { "transform": "translateY(-10vh) scale(1)", "opacity": "0" }
            }
        }
    }
}
