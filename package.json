{
    "name": "@anubis/ds",
    "version": "1.1.0",
    "description": "Anubis World — design system. Source-of-truth tokens.json compiles to a Tailwind preset, CSS variables, theme classes, and React components built on shadcn/ui + Radix Primitives.",
    "private": true,
    "type": "module",
    "main": "dist/tailwind-preset.cjs",
    "module": "dist/react/index.js",
    "types": "dist/react/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js"
        },
        "./tailwind": {
            "default": "./dist/tailwind-preset.cjs"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js"
        },
        "./styles": "./dist/index.css",
        "./styles/variables": "./dist/variables.css",
        "./styles/theme": "./dist/theme.css",
        "./styles/animations": "./dist/animations.css",
        "./tokens": "./dist/tokens.json"
    },
    "files": [
        "tokens.json",
        "dist/"
    ],
    "scripts": {
        "build:tokens": "node scripts/build.js",
        "build:react": "vite build",
        "build:playground": "vite build --config vite.playground.config.ts",
        "build": "npm run build:tokens && npm run build:react && npm run build:playground",
        "prepare": "npm run build:tokens && npm run build:react",
        "dev": "vite --config vite.playground.config.ts"
    },
    "homepage": "https://damanoreshkan-beep.github.io/anubis-ds/",
    "repository": {
        "type": "git",
        "url": "https://github.com/damanoreshkan-beep/anubis-ds.git"
    },
    "license": "UNLICENSED",
    "dependencies": {
        "@radix-ui/react-accordion": "^1.2.2",
        "@radix-ui/react-avatar": "^1.1.3",
        "@radix-ui/react-dialog": "^1.1.5",
        "@radix-ui/react-dropdown-menu": "^2.1.5",
        "@radix-ui/react-label": "^2.1.1",
        "@radix-ui/react-navigation-menu": "^1.2.4",
        "@radix-ui/react-scroll-area": "^1.2.2",
        "@radix-ui/react-slot": "^1.1.1",
        "@radix-ui/react-tabs": "^1.1.2",
        "@radix-ui/react-tooltip": "^1.1.7",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.471.0",
        "sonner": "^1.7.2",
        "tailwind-merge": "^2.6.0",
        "tailwindcss-animate": "^1.0.7"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.7",
        "@types/react-dom": "^19.0.3",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.7.3",
        "vite": "^7.0.0",
        "vite-plugin-dts": "^4.5.0"
    }
}
